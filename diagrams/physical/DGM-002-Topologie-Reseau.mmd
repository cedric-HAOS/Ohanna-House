flowchart TD
    Internet((Internet))

    BOX["BOX-01<br/>Freebox Pop<br/>Passerelle Internet<br/>NAT / WireGuard"]

    LAN["Réseau local"]

    INFRA["INFRA-01<br/>DHCP / NTP / Supervision"]

    ZWAVE["ZWAVE-01<br/>DNS principal<br/>Z-Wave"]

    LINKY["LINKY-01<br/>DNS secondaire<br/>Téléinformation"]

    HA["HA-01<br/>Home Assistant<br/>MQTT"]

    AP["AP-01<br/>Point d'accès Wi-Fi"]

    CLIENTS["Clients réseau<br/>PC / mobiles / objets connectés"]

    Internet --> BOX
    BOX --> LAN

    LAN --> INFRA
    LAN --> ZWAVE
    LAN --> LINKY
    LAN --> HA
    LAN --> AP
    LAN --> CLIENTS

    INFRA -- "DHCP<br/>IP + passerelle + DNS + NTP" --> CLIENTS

    INFRA -- "NTP" --> HA
    INFRA -- "NTP" --> ZWAVE
    INFRA -- "NTP" --> LINKY

    CLIENTS -- "DNS principal" --> ZWAVE
    CLIENTS -- "DNS secondaire" --> LINKY

    HA -- "Pilotage local" --> CLIENTS